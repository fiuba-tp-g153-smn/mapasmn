# mapasmn — single source of truth for all submodule env vars.
# Copy to `.env` (auto-done by `make setup`); per-submodule .env files are
# generated from this one via `scripts/setup-env.sh`. Do not edit submodule
# .env files directly — they get overwritten.

# Shared
APP_ENV=development
LOG_LEVEL=INFO
DEV_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Cross-service S3 / SeaweedFS (provisioned by tiles-processor, consumed by data-service & alerts-service)
S3_TILES_DATA_PORT=9000
S3_TILES_DATA_BUCKET_NAME=tiles-data
S3_ROOT_USER=root_admin
S3_TILES_DATA_TILES_PROCESSOR_USER=tiles_processor
S3_TILES_DATA_DATA_SERVICE_USER=data_service
S3_INTERSECTION_DATA_BUCKET_NAME=intersection-data
S3_INTERSECTION_DATA_ALERTS_SERVICE_USER=alerts_service
S3_BASEMAP_BUCKET_NAME=basemap-tiles

# data-service
DATA_SERVICE_APP_HOST_PORT=6006
DATA_SERVICE_WEB_CONCURRENCY=3
DATA_SERVICE_SYNC_INTERVAL_SECONDS=60
REDIS_URL=redis://redis:6379/0

# alerts-service
ALERTS_SERVICE_APP_HOST_PORT=6007
MYSQL_DATABASE=aviso_gempak
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_HOST=localhost
MYSQL_USER=alerts_service
MYSQL_READONLY_USER=avisos
MYSQL_READONLY_MAX_CONNECTIONS=50
MYSQL_READONLY_MAX_CONNECTIONS_PER_HOUR=10000

# tiles-processor — SeaweedFS
SEAWEEDFS_FILER_ENDPOINT=seaweedfs:8888
SEAWEEDFS_TILE_TTL=6h
SEAWEEDFS_RADAR_TILE_TTL=30d
SEAWEEDFS_METRICS_ADDRESS=
PROMETHEUS_PUSHGATEWAY_HTTP_PROTO=http
PROMETHEUS_PUSHGATEWAY_USER=push_user

# tiles-processor — RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=tiles_processor
RABBITMQ_QUEUE=tiles_work_queue
RABBITMQ_DLQ=tiles_dead_letter_queue
RABBITMQ_DLX=tiles_dlx

# tiles-processor — workers
JOB_TTL_MINUTES=20
GDAL_CACHEMAX=128
CPL_VSIL_CURL_CACHE_SIZE=16777216

# visualizer
VISUALIZER_APP_HOST_PORT=6010
DOCS_HOST_PORT=6011
DOCS_URL=http://localhost:6011
DATA_SERVICE_BASE_URL=http://localhost:6006
ALERTS_SERVICE_BASE_URL=http://localhost:6007
TILE_FORMAT=webp
