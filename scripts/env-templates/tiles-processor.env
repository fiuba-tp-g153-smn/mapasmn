LOG_LEVEL=${LOG_LEVEL}

DATA_DIR=/app/data

# Ports
S3_TILES_DATA_PORT=${S3_TILES_DATA_PORT}

# S3 Root Configuration (Internal Admin)
S3_ROOT_USER=${S3_ROOT_USER}
S3_ROOT_PASSWORD=${DEV_PASSWORD}

# S3 Tiles Data Configuration
S3_TILES_DATA_ENDPOINT=seaweedfs:8333
S3_TILES_DATA_BUCKET_NAME=${S3_TILES_DATA_BUCKET_NAME}
S3_TILES_DATA_SECURE=false

S3_TILES_DATA_TILES_PROCESSOR_USER=${S3_TILES_DATA_TILES_PROCESSOR_USER}
S3_TILES_DATA_TILES_PROCESSOR_PASSWORD=${DEV_PASSWORD}
S3_TILES_DATA_DATA_SERVICE_USER=${S3_TILES_DATA_DATA_SERVICE_USER}
S3_TILES_DATA_DATA_SERVICE_PASSWORD=${DEV_PASSWORD}

# S3 Intersection Data Configuration (alerts-service geojson layers)
S3_INTERSECTION_DATA_BUCKET_NAME=${S3_INTERSECTION_DATA_BUCKET_NAME}
S3_INTERSECTION_DATA_ALERTS_SERVICE_USER=${S3_INTERSECTION_DATA_ALERTS_SERVICE_USER}
S3_INTERSECTION_DATA_ALERTS_SERVICE_PASSWORD=${DEV_PASSWORD}

# Basemap bucket (consumed by data-service)
S3_BASEMAP_BUCKET_NAME=${S3_BASEMAP_BUCKET_NAME}

# SeaweedFS Filer
SEAWEEDFS_FILER_ENDPOINT=${SEAWEEDFS_FILER_ENDPOINT}
SEAWEEDFS_TILE_TTL=${SEAWEEDFS_TILE_TTL}
SEAWEEDFS_RADAR_TILE_TTL=${SEAWEEDFS_RADAR_TILE_TTL}

# SeaweedFS metrics (Prometheus push gateway — leave SEAWEEDFS_METRICS_ADDRESS empty to disable)
SEAWEEDFS_METRICS_ADDRESS=${SEAWEEDFS_METRICS_ADDRESS}
PROMETHEUS_PUSHGATEWAY_HTTP_PROTO=${PROMETHEUS_PUSHGATEWAY_HTTP_PROTO}
PROMETHEUS_PUSHGATEWAY_USER=${PROMETHEUS_PUSHGATEWAY_USER}
PROMETHEUS_PUSHGATEWAY_PASS=${DEV_PASSWORD}

RABBITMQ_PORT=${RABBITMQ_PORT}
RABBITMQ_MGMT_PORT=${RABBITMQ_MGMT_PORT}
RABBITMQ_USER=${RABBITMQ_USER}
RABBITMQ_PASSWORD=${DEV_PASSWORD}
RABBITMQ_QUEUE=${RABBITMQ_QUEUE}
RABBITMQ_DLQ=${RABBITMQ_DLQ}
RABBITMQ_DLX=${RABBITMQ_DLX}

JOB_TTL_MINUTES=${JOB_TTL_MINUTES}

GDAL_CACHEMAX=${GDAL_CACHEMAX}
CPL_VSIL_CURL_CACHE_SIZE=${CPL_VSIL_CURL_CACHE_SIZE}
