APP_HOST_PORT=${ALERTS_SERVICE_APP_HOST_PORT}
APP_ENV=${APP_ENV}
LOG_LEVEL=${LOG_LEVEL}

SETTINGS_FILE=/config/settings.json

# S3 backup (empty = disabled in dev; alerts-service skips S3 reconciliation when unset)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_SECURE=true

MYSQL_HOST=${MYSQL_HOST}
MYSQL_PORT=${MYSQL_PORT}
MYSQL_DATABASE=${MYSQL_DATABASE}
MYSQL_ROOT_HOST=${MYSQL_ROOT_HOST}
MYSQL_ROOT_PASSWORD=${DEV_PASSWORD}

MYSQL_USER=${MYSQL_USER}
MYSQL_PASSWORD=${DEV_PASSWORD}

MYSQL_READONLY_USER=${MYSQL_READONLY_USER}
MYSQL_READONLY_PASSWORD=${DEV_PASSWORD}
MYSQL_READONLY_MAX_CONNECTIONS=${MYSQL_READONLY_MAX_CONNECTIONS}
MYSQL_READONLY_MAX_CONNECTIONS_PER_HOUR=${MYSQL_READONLY_MAX_CONNECTIONS_PER_HOUR}

OUTPUT_DIR=/app/output/alerts
ALERT_CACHE_DIR=/app/cache
